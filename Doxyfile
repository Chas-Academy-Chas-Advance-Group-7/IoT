# Doxyfile for ESP32 Sensor Firmware

# Project info
PROJECT_NAME           = "ESP32 Sensor Firmware"
PROJECT_BRIEF          = "Documentation for sensor unit, BLE, DHT, and state management."
PROJECT_NUMBER         = 1.0
OUTPUT_DIRECTORY       = docs

# Input
INPUT                  = ./
FILE_PATTERNS          = *.h *.cpp
RECURSIVE              = YES

# Exclude external headers
EXCLUDE_PATTERNS       = */Arduino.h \
                         */DHT.h \
                         */ArduinoBLE.h \
                         */Wire.h \
                         */WiFi.h \
                         */HTTPClient.h \
                         */freertos/* \
                         */lwip/*

# Extraction settings
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES

# HTML output
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_TREEVIEW      = YES
FULL_PATH_NAMES        = NO
SOURCE_BROWSER         = YES          # Links to source files in HTML
INLINE_SOURCES         = YES          # Show source code inline

# Graphs and diagrams
HAVE_DOT               = YES
CLASS_DIAGRAMS         = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
DOT_IMAGE_FORMAT       = svg

# Warnings
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES

# Markdown support (optional)
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES